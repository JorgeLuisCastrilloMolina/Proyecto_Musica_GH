@model Proyecto_Musica_GHBLL.Dtos.Cancion.CancionDto

<div class="modal fade" id="modalEditarCancion" tabindex="-1" aria-labelledby="modalEditarCancionLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Editar Canción</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="formEditarCancion" asp-action="EditarCancion">
                    <!-- Campo oculto para ID -->
                    <input type="hidden" id="CancionId" name="Cancion_ID" />

                    <div class="mb-3">
                        <label for="TituloEditar" class="form-label">Título</label>
                        <input type="text" class="form-control" id="TituloEditar" name="Titulo" required />
                    </div>

                    <div class="mb-3">
                        <label for="DuracionEditar" class="form-label">Duración</label>
                        <input type="number" class="form-control" id="DuracionEditar" name="Duracion" required />
                    </div>

                    <div class="mb-3">
                        <label for="Fecha_publicacionEditar" class="form-label">Fecha Publicación</label>
                        <input type="date" class="form-control" id="Fecha_publicacionEditar" name="Fecha_publicacion" />
                    </div>


                    <div class="mb-3">
                        <label for="URL_cancion" class="form-label">URL Canción</label>
                        <input type="text" class="form-control" id="URL_cancion" name="URL_cancion" />
                    </div>

                    <div class="mb-3">
                        <label for="AlbumEditarSelect" class="form-label">Álbum</label>
                        <select class="form-select" id="AlbumEditarSelect" name="Album_ID" required>
                            <option value="">-- Seleccione un álbum --</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label for="ArtistaEditarPreview" class="form-label">Artista del álbum</label>
                        <input type="text" class="form-control" id="ArtistaEditarPreview" value="Seleccione un álbum" readonly />
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
                <button type="button" class="btn btn-primary" id="btnEditarCancion">Guardar cambios</button>
            </div>
        </div>
    </div>
</div>
