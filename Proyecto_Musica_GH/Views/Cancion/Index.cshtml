@using Proyecto_Musica_GHBLL.Dtos.Cancion
@model List<CancionDto>

@{
    ViewData["Title"] = "Canciones";
}

<h1>Lista de Canciones</h1>

<button type="button" class="btn btn-success" data-bs-toggle="modal" data-bs-target="#modalCrearCancion">
    Agregar Canción
</button>

<table id="tblCancion" class="table table-striped" style="width:100%">
    <thead>
        <tr>
            <th>Id</th>
            <th>Título</th>
            <th>Duración</th>
            <th>Fecha Publicación</th>
            <th>Álbum</th>
            <th>Reproducir</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody></tbody>
</table>

<hr />

<!-- 🎧 REPRODUCTOR GLOBAL -->
<div id="reproductorGlobal" style="position:fixed; bottom:0; width:100%; background:#222; color:white; padding:10px; z-index:999;">

    <strong id="tituloActual">Ninguna canción</strong>

    <br />

    <audio id="audioPlayer" controls style="width:300px;"></audio>

    <br />

    <button id="btnPrev" class="btn btn-light">⏮</button>
    <button id="btnPlay" class="btn btn-success">▶</button>
    <button id="btnStop" class="btn btn-danger">⏹</button>
    <button id="btnNext" class="btn btn-light">⏭</button>
</div>

@await Html.PartialAsync("_CreateCancion")
@await Html.PartialAsync("_EditCancion")

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/Cancion.js"></script>
}