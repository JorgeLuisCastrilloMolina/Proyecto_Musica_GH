<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Proyecto_Musica_GH</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Proyecto_Musica_GH.styles.css" asp-append-version="true" />
</head>
<body>
    <div class="app-shell">
        <div class="app-frame">
            <aside class="app-sidebar">
                <a class="app-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    <span class="app-brand-title">GrooveHub</span>
                    <span class="app-brand-subtitle">Tu biblioteca musical universitaria</span>
                </a>

                <nav class="app-nav">
                    <a class="app-nav-link" asp-area="" asp-controller="Home" asp-action="Index">Inicio</a>
                    <a class="app-nav-link" asp-area="" asp-controller="Cancion" asp-action="Index">Canciones</a>
                    <a class="app-nav-link" asp-area="" asp-controller="Playlist" asp-action="Index">Playlists</a>
                    <a class="app-nav-link" asp-area="" asp-controller="Artista" asp-action="Index">Artistas</a>
                    <a class="app-nav-link" asp-area="" asp-controller="Album" asp-action="Index">Álbumes</a>
                    <a class="app-nav-link" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
                </nav>

                <p class="footer-note">Un look inspirado en plataformas de streaming, adaptado a tu proyecto MVC.</p>
            </aside>

            <main class="app-main">
                <section class="app-header">
                    <div>
                        <h1>Biblioteca Musical</h1>
                        <p>Gestiona playlists, artistas, álbumes y canciones desde una interfaz con mejor jerarquía visual y foco en demo.</p>
                    </div>
                </section>

                @RenderBody()
            </main>
        </div>
    </div>

    <div class="player-dock">
        <div class="player-meta">
            <span class="player-label">Reproduciendo</span>
            <span id="tituloActual" class="player-title">Ninguna canción</span>
        </div>

        <div class="player-controls">
            <button id="btnPrev" class="btn btn-outline-secondary btn-sm">⏮</button>
            <button id="btnPlay" class="btn btn-success btn-sm">▶</button>
            <button id="btnStop" class="btn btn-outline-danger btn-sm">⏹</button>
            <button id="btnNext" class="btn btn-outline-secondary btn-sm">⏭</button>
        </div>

        <audio id="audioPlayer"></audio>
    </div>



    <!-- Librerías base -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Validación -->
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/dist/jquery.validate.unobtrusive.min.js"></script>

    <!-- DataTables y SweetAlert -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/pdfmake.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/vfs_fonts.js"></script>
    <script src="https://cdn.datatables.net/v/bs5/dt-2.3.6/datatables.min.js"></script>
    <link href="https://cdn.datatables.net/v/bs5/dt-2.3.6/datatables.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <!-- Reproductor global -->
    <script src="~/js/ReproductorGlobal.js"></script>

    <!-- Scripts propios -->
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>
