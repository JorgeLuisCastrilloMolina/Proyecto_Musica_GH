@model Proyecto_Musica_GHBLL.Dtos.Album.AlbumDto

<div class="modal fade" id="modalCrearAlbum" tabindex="-1" aria-labelledby="modalCrearAlbumLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Crear Álbum</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="formCrearAlbum" asp-action="AgregarAlbum">
                    <div class="mb-3">
                        <label asp-for="Titulo" class="form-label">Título</label>
                        <input asp-for="Titulo" class="form-control" required />
                        <span asp-validation-for="Titulo" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Fecha_publicacion" class="form-label">Fecha Publicación</label>
                        <input asp-for="Fecha_publicacion" type="date" class="form-control" />
                        <span asp-validation-for="Fecha_publicacion" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Artista_ID" class="form-label">Artista</label>
                        <select asp-for="Artista_ID" class="form-select" id="ArtistaSelect" required>
                            <option value="">-- Seleccione un artista --</option>
                        </select>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
                <button type="button" class="btn btn-primary" id="btnGuardarAlbum">Guardar Álbum</button>
            </div>
        </div>
    </div>
</div>
