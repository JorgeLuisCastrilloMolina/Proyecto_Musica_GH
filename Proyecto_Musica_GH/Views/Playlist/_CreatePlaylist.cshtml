@model Proyecto_Musica_GHBLL.Dtos.Playlist.PlaylistDto

<div class="modal fade" id="modalCrearPlaylist" tabindex="-1" aria-labelledby="modalCrearPlaylistLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Crear Playlist</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="formCrearPlaylist" asp-action="CrearPlaylist">
                    <div class="mb-3">
                        <label asp-for="Nombre" class="form-label">Nombre</label>
                        <input asp-for="Nombre" class="form-control" required />
                        <span asp-validation-for="Nombre" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Fecha_creacion" class="form-label">Fecha de Creación</label>
                        <input asp-for="Fecha_creacion" type="date" class="form-control" value="@DateTime.Today.ToString("yyyy-MM-dd")" required />
                        <span asp-validation-for="Fecha_creacion" class="text-danger"></span>
                    </div>
                    <input asp-for="Usuario_ID" type="hidden" value="1" />
                    <p class="text-muted small mb-0">La playlist se creará para el usuario demo actual.</p>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
                <button type="button" class="btn btn-primary" id="btnGuardarPlaylist">Guardar Playlist</button>
            </div>
        </div>
    </div>
</div>
