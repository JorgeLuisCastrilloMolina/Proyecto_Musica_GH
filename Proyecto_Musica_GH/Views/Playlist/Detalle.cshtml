@model Proyecto_Musica_GH.Models.PlaylistDetalleViewModel

@{
    ViewData["Title"] = "Detalle de Playlist";
}

<section class="hero-card mb-4">
    <span class="eyebrow">Curated playlist</span>
    <div class="d-flex flex-column flex-lg-row justify-content-between gap-3">
        <div>
            <h1 class="mb-2">@Model.Playlist?.Nombre</h1>
            <p class="text-muted mb-0">
                Curada por @Model.Playlist?.UsuarioNombre · Creada el @Model.Playlist?.Fecha_creacion
            </p>
        </div>
        <div class="d-flex gap-2">
            <a class="btn btn-outline-primary" asp-controller="Cancion" asp-action="Index">Explorar canciones</a>
            <a class="btn btn-outline-secondary" asp-controller="Playlist" asp-action="Index">Volver</a>
        </div>
    </div>

    <div class="metric-grid">
        <div class="metric-card">
            <span class="metric-label">Tracks</span>
            <span class="metric-value">@Model.Canciones.Count</span>
        </div>
        <div class="metric-card">
            <span class="metric-label">Disponibles</span>
            <span class="metric-value">@Model.CancionesDisponibles.Count</span>
        </div>
    </div>
</section>

<div class="row g-4">
    <div class="col-lg-4">
        <div class="card">
            <div class="card-body">
                <h2 class="section-title">Agregar canción</h2>

                @if (Model.CancionesDisponibles.Any())
                {
                    <form id="formAgregarCancionPlaylist">
                        <input type="hidden" name="Playlist_ID" value="@Model.Playlist?.Playlist_ID" />

                        <div class="mb-3">
                            <label for="Cancion_ID" class="form-label">Canción</label>
                            <select id="Cancion_ID" name="Cancion_ID" class="form-select" required>
                                <option value="">Seleccione una canción</option>
                                @foreach (var cancion in Model.CancionesDisponibles)
                                {
                                    <option value="@cancion.Cancion_ID">
                                        @cancion.Titulo (@cancion.AlbumNombre)
                                    </option>
                                }
                            </select>
                        </div>

                        <div class="mb-3">
                            <label for="Orden" class="form-label">Orden</label>
                            <input id="Orden" name="Orden" type="number" min="1" class="form-control" value="@(Model.Canciones.Count + 1)" />
                        </div>

                        <button type="submit" class="btn btn-primary w-100">Agregar a playlist</button>
                    </form>
                }
                else
                {
                    <p class="text-muted mb-0">No hay canciones disponibles para agregar.</p>
                }
            </div>
        </div>
    </div>

    <div class="col-lg-8">
        <div class="card">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h2 class="section-title mb-0">Canciones de la playlist</h2>
                    <span class="pill">@Model.Canciones.Count tracks</span>
                </div>

                @if (Model.Canciones.Any())
                {
                    <div class="table-responsive">
                        <table class="table align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Orden</th>
                                    <th>Canción</th>
                                    <th>Álbum</th>
                                    <th>Duración</th>
                                    <th>Reproducir</th>
                                    <th class="text-end">Acciones</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.Canciones)
                                {
                                    <tr>
                                        <td>@(item.Orden?.ToString() ?? "-")</td>
                                        <td>@item.CancionTitulo</td>
                                        <td>@(string.IsNullOrWhiteSpace(item.AlbumNombre) ? "-" : item.AlbumNombre)</td>
                                        <td>@(item.Duracion?.ToString() ?? "-")</td>
                                        <td>
                                            <button
                                                type="button"
                                                class="btn btn-sm btn-success btn-play"
                                                data-id="@item.Cancion_ID">
                                                ▶ Play
                                            </button>
                                        </td>
                                        <td class="text-end">
                                            <button
                                                type="button"
                                                class="btn btn-sm btn-outline-danger btn-eliminar-relacion"
                                                data-id="@item.LC_REL_ID">
                                                Quitar
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <p class="text-muted mb-0">Esta playlist todavía no tiene canciones.</p>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/PlaylistDetalle.js" asp-append-version="true"></script>
}
